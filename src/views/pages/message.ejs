<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div
                class="card shadow-sm border-0 border-top border-<%= type === 'success' ? 'success' : 'danger' %> border-4">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi <%= type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-x-circle-fill text-danger' %>"
                            style="font-size: 4rem;"></i>
                    </div>

                    <h2 class="mb-3">
                        <%= title %>
                    </h2>
                    <p class="text-muted mb-3">
                        <%= message %>
                    </p>

                    <% if (locals.email) { %>
                        <div class="alert alert-light border d-inline-block px-4 py-2">
                            <i class="bi bi-envelope me-2"></i>
                            <strong>
                                <%= email %>
                            </strong>
                        </div>
                        <% } %>

                            <div class="d-flex gap-3 justify-content-center mt-4">
                                <% if (link) { %>
                                    <a href="<%= link.url %>" class="btn btn-primary">
                                        <i
                                            class="bi <%= type === 'success' ? 'bi-box-arrow-in-right' : 'bi-arrow-clockwise' %> me-2"></i>
                                        <%= link.text %>
                                    </a>
                                    <% } %>
                                        <a href="/" class="btn btn-outline-secondary">
                                            <i class="bi bi-house me-2"></i>Go Home
                                        </a>
                            </div>
                </div>
            </div>
        </div>
    </div>
</div>
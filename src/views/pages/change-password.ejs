<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
                        <h2 class="mt-3">Change Password</h2>
                        <p class="text-muted">Update your password to keep your account secure</p>
                    </div>

                    <% if (locals.error) { %>
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>
                                <%= error %>
                            </div>
                        </div>
                        <% } %>

                            <form method="POST" action="/change-password">
                                <div class="mb-3">
                                    <label for="currentPassword" class="form-label">Current Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                        <input type="password" class="form-control" id="currentPassword"
                                            name="currentPassword" placeholder="••••••••" required autofocus>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="newPassword" class="form-label">New Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                                        <input type="password" class="form-control" id="newPassword" name="newPassword"
                                            placeholder="••••••••" required minlength="6">
                                    </div>
                                    <small class="form-text text-muted">Minimum 6 characters</small>
                                </div>

                                <div class="mb-4">
                                    <label for="confirmPassword" class="form-label">Confirm New Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                                        <input type="password" class="form-control" id="confirmPassword"
                                            name="confirmPassword" placeholder="••••••••" required minlength="6">
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary w-100 py-2">
                                    <i class="bi bi-check-circle me-2"></i>Update Password
                                </button>
                            </form>

                            <hr class="my-4">

                            <p class="text-center text-muted mb-0">
                                <a href="/dashboard" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                                </a>
                            </p>
                </div>
            </div>
        </div>
    </div>
</div>
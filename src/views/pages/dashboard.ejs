<div class="d-flex" style="min-height: calc(100vh - 140px);">
    <!-- Sidebar -->
    <div class="bg-white border-end shadow-sm" style="width: 250px; flex-shrink: 0;">
        <div class="p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <i class="bi bi-person-circle text-primary me-3" style="font-size: 2.5rem;"></i>
                <div>
                    <h6 class="mb-0">
                        <%= user.name %>
                    </h6>
                    <small class="text-muted">
                        <%= user.email %>
                    </small>
                </div>
            </div>

            <nav class="nav flex-column">
                <a class="nav-link text-dark active bg-primary text-white rounded mb-1" href="/dashboard">
                    <i class="bi bi-speedometer2 me-2"></i>Overview
                </a>
                <a class="nav-link text-secondary hover-link mb-1" href="/edit-profile">
                    <i class="bi bi-person me-2"></i>Edit Profile
                </a>
                <a class="nav-link text-secondary hover-link mb-1" href="/change-password">
                    <i class="bi bi-shield-lock me-2"></i>Change Password
                </a>
            </nav>

            <div class="mt-4 pt-3 border-top">
                <a href="/logout" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-1 bg-light">
        <div class="container-fluid p-4">
            <!-- Header -->
            <div class="mb-4">
                <h2 class="mb-1">Dashboard</h2>
                <p class="text-muted">Welcome back, <strong>
                        <%= user.name %>
                    </strong>! Here's what's happening with your account.</p>
            </div>

            <!-- Stats Cards -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Account Status</p>
                                    <h4 class="mb-0">
                                        <% if (user.verified) { %>
                                            <span class="badge bg-success">Active</span>
                                            <% } else { %>
                                                <span class="badge bg-warning">Pending</span>
                                                <% } %>
                                    </h4>
                                </div>
                                <i class="bi <%= user.verified ? 'bi-check-circle-fill text-success' : 'bi-clock text-warning' %>"
                                    style="font-size: 2rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Email Status</p>
                                    <h4 class="mb-0">
                                        <% if (user.verified) { %>
                                            <span class="badge bg-success">Verified</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">Unverified</span>
                                                <% } %>
                                    </h4>
                                </div>
                                <i class="bi bi-envelope-check-fill text-primary" style="font-size: 2rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Security Level</p>
                                    <h4 class="mb-0"><span class="badge bg-info">Standard</span></h4>
                                </div>
                                <i class="bi bi-shield-check text-primary" style="font-size: 2rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Last Login</p>
                                    <h6 class="mb-0">Just now</h6>
                                </div>
                                <i class="bi bi-clock-history text-primary" style="font-size: 2rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content Sections -->
            <div class="row g-4">
                <!-- Profile Information -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Profile Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="text-muted small">Full Name</label>
                                <p class="mb-0 fw-bold">
                                    <%= user.name %>
                                </p>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted small">Email Address</label>
                                <p class="mb-0 fw-bold">
                                    <%= user.email %>
                                </p>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted small">Verification Status</label>
                                <p class="mb-0">
                                    <% if (user.verified) { %>
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Verified
                                        </span>
                                        <% } else { %>
                                            <span class="badge bg-warning">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Not Verified
                                            </span>
                                            <% } %>
                                </p>
                                <% if (!user.verified) { %>
                                    <small class="text-muted">Please check your email to verify your account.</small>
                                    <% } %>
                            </div>
                            <div class="d-grid">
                                <a href="/edit-profile" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil me-2"></i>Edit Profile
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Account Activity -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0"><i class="bi bi-activity me-2"></i>Recent Activity</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
                                <i class="bi bi-check-circle-fill text-success me-3 mt-1"></i>
                                <div class="flex-grow-1">
                                    <p class="mb-0 fw-bold">Account Created</p>
                                    <small class="text-muted">Your account was successfully created</small>
                                </div>
                                <small class="text-muted">Today</small>
                            </div>

                            <% if (user.verified) { %>
                                <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
                                    <i class="bi bi-envelope-check-fill text-primary me-3 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <p class="mb-0 fw-bold">Email Verified</p>
                                        <small class="text-muted">Email address verified successfully</small>
                                    </div>
                                    <small class="text-muted">Today</small>
                                </div>
                                <% } %>

                                    <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
                                        <i class="bi bi-box-arrow-in-right text-info me-3 mt-1"></i>
                                        <div class="flex-grow-1">
                                            <p class="mb-0 fw-bold">Logged In</p>
                                            <small class="text-muted">Successful login to your account</small>
                                        </div>
                                        <small class="text-muted">Just now</small>
                                    </div>

                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-shield-check text-secondary me-3 mt-1"></i>
                                        <div class="flex-grow-1">
                                            <p class="mb-0 fw-bold">Security Check</p>
                                            <small class="text-muted">Account security verified</small>
                                        </div>
                                        <small class="text-muted">Today</small>
                                    </div>
                        </div>
                    </div>
                </div>

                <!-- Security Settings -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Security Settings</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="mb-0 fw-bold">Password</p>
                                    <small class="text-muted">Last changed: Never</small>
                                </div>
                                <a href="/change-password" class="btn btn-sm btn-outline-primary">Change</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <a href="/edit-profile" class="btn btn-outline-primary text-start">
                                    <i class="bi bi-person-circle me-2"></i>Update Profile Information
                                </a>
                                <a href="/change-password" class="btn btn-outline-primary text-start">
                                    <i class="bi bi-key me-2"></i>Change Password
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-link {
        transition: all 0.2s;
        border-radius: 0.25rem;
        padding: 0.5rem 0.75rem;
    }

    .hover-link:hover {
        background-color: #f8f9fa;
        color: #212529 !important;
    }
</style>
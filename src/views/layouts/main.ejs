<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | Email Verification App
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">
                <i class="bi bi-envelope-check me-2"></i>Email Verify
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-secondary ms-2" href="/logout">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </a>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary ms-2" href="/register">Register</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <%- body %>
    </main>

    <footer class="footer bg-light border-top mt-5 py-4">
        <div class="container text-center text-muted">
            <p class="mb-0">&copy; 2026 Email Verification App</p>
        </div>
    </footer>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
        <!-- Success Toast -->
        <% if (locals.success && success.length> 0) { %>
            <% success.forEach(function(message, index) { %>
                <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive"
                    aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000" id="successToast<%= index %>">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <%= message %>
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                            aria-label="Close"></button>
                    </div>
                </div>
                <% }); %>
                    <% } %>

                        <!-- Error Toast -->
                        <% if (locals.error && error.length> 0) { %>
                            <% error.forEach(function(message, index) { %>
                                <div class="toast align-items-center text-white bg-danger border-0" role="alert"
                                    aria-live="assertive" aria-atomic="true" data-bs-autohide="true"
                                    data-bs-delay="5000" id="errorToast<%= index %>">
                                    <div class="d-flex">
                                        <div class="toast-body">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                            <%= message %>
                                        </div>
                                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                            data-bs-dismiss="toast" aria-label="Close"></button>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } %>

                                        <!-- Info Toast -->
                                        <% if (locals.info && info.length> 0) { %>
                                            <% info.forEach(function(message, index) { %>
                                                <div class="toast align-items-center text-white bg-info border-0"
                                                    role="alert" aria-live="assertive" aria-atomic="true"
                                                    data-bs-autohide="true" data-bs-delay="5000"
                                                    id="infoToast<%= index %>">
                                                    <div class="d-flex">
                                                        <div class="toast-body">
                                                            <i class="bi bi-info-circle-fill me-2"></i>
                                                            <%= message %>
                                                        </div>
                                                        <button type="button"
                                                            class="btn-close btn-close-white me-2 m-auto"
                                                            data-bs-dismiss="toast" aria-label="Close"></button>
                                                    </div>
                                                </div>
                                                <% }); %>
                                                    <% } %>

                                                        <!-- Warning Toast -->
                                                        <% if (locals.warning && warning.length> 0) { %>
                                                            <% warning.forEach(function(message, index) { %>
                                                                <div class="toast align-items-center text-dark bg-warning border-0"
                                                                    role="alert" aria-live="assertive"
                                                                    aria-atomic="true" data-bs-autohide="true"
                                                                    data-bs-delay="5000" id="warningToast<%= index %>">
                                                                    <div class="d-flex">
                                                                        <div class="toast-body">
                                                                            <i
                                                                                class="bi bi-exclamation-circle-fill me-2"></i>
                                                                            <%= message %>
                                                                        </div>
                                                                        <button type="button"
                                                                            class="btn-close me-2 m-auto"
                                                                            data-bs-dismiss="toast"
                                                                            aria-label="Close"></button>
                                                                    </div>
                                                                </div>
                                                                <% }); %>
                                                                    <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Toast Initialization Script -->
    <script>
        // Initialize and show all toasts
        document.addEventListener('DOMContentLoaded', function () {
            const toastElList = document.querySelectorAll('.toast');
            toastElList.forEach(function (toastEl) {
                const toast = new bootstrap.Toast(toastEl);
                toast.show();
            });
        });
    </script>
</body>

</html>